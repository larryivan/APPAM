# 服务器配置
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=19454

# Paths
APPAM_REPO_ROOT=/opt/appam
APPAM_BACKEND_ROOT=/opt/appam/backend
APPAM_PROJECTS_ROOT=/workspaces/projects
APPAM_DATABASES_ROOT=/databases

# Local executor
PIPELINE_JOB_TIMEOUT=604800
APPAM_DB_PATH=/data/app_database.db
SOCKETIO_ASYNC_MODE=threading

# Snakemake and workflow runtime
APPAM_SNAKEMAKE_BIN=snakemake
APPAM_SMK_ROOT=/opt/appam/APPAM-SMK-main
APPAM_SMK_METAWRAP_ENV=
APPAM_SMK_PYDAMAGE_ENV=
APPAM_SMK_CHECKM_DB=
APPAM_SMK_GUNC_DB=
APPAM_PALEOPROTEOMICS_ROOT=/opt/appam/appam-paleoproteomics-main
APPAM_PALEO_DOTNET_BIN=dotnet
APPAM_PALEO_MAXQUANT_CMD=/opt/tools/MaxQuant_v2.7.5.0/bin/MaxQuantCmd.dll
APPAM_PALEO_THERMO_RAW_FILE_PARSER=ThermoRawFileParser
APPAM_PALEO_TIMSCONVERT_BIN=timsconvert
APPAM_PALEO_OPENMS_FILECONVERTER=FileConverter

# OpenCode integration (API service)
OPENCODE_PORT=19455
OPENCODE_BASE_URL=http://127.0.0.1:19455
OPENCODE_AGENT=build
# OPENCODE_PROVIDER_ID=anthropic
# OPENCODE_MODEL_ID=claude-3-5-sonnet
OPENCODE_TIMEOUT=120
OPENCODE_SYSTEM_PROMPT_PATH=opencode/system_prompt.txt
OPENCODE_AGENTS_TEMPLATE_PATH=opencode/AGENTS.md
OPENCODE_SKILL_PATH=
OPENCODE_SKILL_FILENAMES=SKILL.md,skill.md
OPENCODE_PERMISSIONS=bash,edit,webfetch,external_directory
OPENCODE_PERMISSION_PATTERN=*
# OPENCODE_IGNORE_PROXY=true
# NO_PROXY=127.0.0.1,localhost,0.0.0.0
# no_proxy=127.0.0.1,localhost,0.0.0.0

# OpenCode CLI integration (terminal UI)
OPENCODE_CLI_COMMAND=opencode
OPENCODE_CLI_AGENT=build
OPENCODE_CLI_AGENTS_PATH=/opt/appam/backend/opencode/AGENTS.md
OPENCODE_CLI_SYSTEM_PROMPT_PATH=/opt/appam/backend/opencode/system_prompt.txt
# OPENCODE_LLM_PROVIDER_ID=openai
# OPENCODE_LLM_MODEL=gpt-4o-mini
OPENCODE_LLM_API_KEY=
OPENCODE_LLM_BASE_URL=
